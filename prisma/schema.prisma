// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =====================================================
// MODELO DE DATOS: Sistema FinTech Premium
// =====================================================

// 1. USUARIOS Y AUTENTICACIÓN
model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String    @map("password_hash")
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  avatarUrl      String?   @map("avatar_url")
  phone          String?
  timezone       String    @default("America/Santiago")
  currencyPref   String    @default("CLP") @map("currency_pref")
  isAdmin        Boolean   @default(false) @map("is_admin")
  emailVerified  DateTime? @map("email_verified")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  lastLogin      DateTime? @map("last_login")

  // Relations
  ownedBranches  Branch[]       @relation("BranchOwner")
  memberships    BranchMember[]
  expenses       Expense[]      @relation("ExpenseCreator")
  splits         ExpenseSplit[]
  documents      Document[]     @relation("DocumentUploader")
  activities     Activity[]
  paidExpenses   Expense[]      @relation("ExpensePayer")

  @@map("users")
}

// 2. SUCURSALES / ESPACIOS (Multi-entidad)
model Branch {
  id          String   @id @default(uuid())
  ownerId     String   @map("owner_id")
  name        String
  type        String   // 'home', 'office', 'vacation', 'business'
  description String?
  color       String   @default("#6366F1")
  currency    String   @default("CLP")
  isActive    Boolean  @default(true) @map("is_active")
  settings    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  owner       User           @relation("BranchOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     BranchMember[]
  categories  Category[]
  expenses    Expense[]
  documents   Document[]
  activities  Activity[]

  @@map("branches")
}

// 3. MEMBRESÍAS DE USUARIOS EN SUCURSALES (M:N)
model BranchMember {
  id                  String   @id @default(uuid())
  branchId            String   @map("branch_id")
  userId              String   @map("user_id")
  role                String   @default("member") // 'owner', 'admin', 'member', 'viewer'
  canCreateExpenses   Boolean  @default(true) @map("can_create_expenses")
  canApprove          Boolean  @default(false) @map("can_approve")
  defaultSplitPercent Decimal? @map("default_split_percent")
  joinedAt            DateTime @default(now()) @map("joined_at")

  // Relations
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([branchId, userId])
  @@map("branch_members")
}

// 4. CATEGORÍAS DE GASTOS (Por sucursal)
model Category {
  id          String   @id @default(uuid())
  branchId    String   @map("branch_id")
  name        String
  icon        String   @default("receipt")
  color       String   @default("#64748B")
  parentId    String?  @map("parent_id")
  isSystem    Boolean  @default(false) @map("is_system")
  budgetLimit Decimal? @map("budget_limit")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  branch   Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  parent   Category?   @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[]  @relation("CategoryHierarchy")
  expenses Expense[]

  @@map("categories")
}

// 5. GASTOS (Core del sistema)
model Expense {
  id             String    @id @default(uuid())
  branchId       String    @map("branch_id")
  createdBy      String    @map("created_by")
  categoryId     String?   @map("category_id")
  
  // Datos del gasto
  title          String
  description    String?
  amount         Decimal   @db.Decimal(15, 2)
  currency       String    @default("CLP")
  
  // Ciclo de vida (Core requirement)
  status         String    @default("pending") 
  // 'pending', 'funds_assigned', 'paid', 'cancelled'
  
  // Fechas
  expenseDate    DateTime  @map("expense_date")
  dueDate        DateTime? @map("due_date")
  paidAt         DateTime? @map("paid_at")
  
  // Método de pago
  paymentMethod  String?   @map("payment_method") // 'cash', 'transfer', 'credit', 'debit'
  paidBy         String?   @map("paid_by")
  
  // División
  isSplit        Boolean   @default(false) @map("is_split")
  splitType      String?   @map("split_type") // 'equal', 'percentage', 'amount'
  
  // Metadata
  tags           String[]
  location       Json?
  metadata       Json      @default("{}")
  
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  branch    Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  creator   User           @relation("ExpenseCreator", fields: [createdBy], references: [id])
  category  Category?      @relation(fields: [categoryId], references: [id])
  payer     User?          @relation("ExpensePayer", fields: [paidBy], references: [id])
  splits    ExpenseSplit[]
  documents Document[]

  @@index([branchId, expenseDate])
  @@index([status])
  @@map("expenses")
}

// 6. PARTICIPACIONES/DIVISIONES DE GASTOS
model ExpenseSplit {
  id          String    @id @default(uuid())
  expenseId   String    @map("expense_id")
  userId      String    @map("user_id")
  
  // Monto asignado
  amount      Decimal   @db.Decimal(15, 2)
  percentage  Decimal?  @db.Decimal(5, 2)
  
  // Estado individual
  status      String    @default("pending") // 'pending', 'assigned', 'paid'
  
  assignedAt  DateTime? @map("assigned_at")
  paidAt      DateTime? @map("paid_at")

  // Relations
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
  @@index([userId, status])
  @@map("expense_splits")
}

// 7. BOVEDA DE DOCUMENTOS (Gestión de boletas)
model Document {
  id              String   @id @default(uuid())
  expenseId       String?  @map("expense_id")
  branchId        String   @map("branch_id")
  uploadedBy      String   @map("uploaded_by")
  
  // Archivo
  fileName        String   @map("file_name")
  fileType        String   @map("file_type") // 'application/pdf', 'image/jpeg'
  fileSize        BigInt   @map("file_size")
  storageKey      String   @map("storage_key")
  
  // Previsualización
  thumbnailUrl    String?  @map("thumbnail_url")
  previewUrl      String?  @map("preview_url")
  
  // OCR/Extracción
  extractedText   String?  @map("extracted_text")
  metadata        Json     @default("{}")
  
  // Estado
  isVerified      Boolean  @default(false) @map("is_verified")
  
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  expense Expense? @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  branch  Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  uploader User   @relation("DocumentUploader", fields: [uploadedBy], references: [id])

  @@index([expenseId])
  @@map("documents")
}

// 8. NOTIFICACIONES Y ACTIVIDAD
model Activity {
  id          String    @id @default(uuid())
  branchId    String?   @map("branch_id")
  userId      String?   @map("user_id")
  
  type        String    // 'expense_created', 'payment_made', 'split_assigned', etc.
  entityType  String?   @map("entity_type") // 'expense', 'document', 'payment'
  entityId    String?   @map("entity_id")
  
  title       String
  description String?
  metadata    Json      @default("{}")
  
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([branchId, createdAt])
  @@map("activities")
}
